# Discord bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=replace-with-discord-bot-token

# Discord server ID, not the application/client ID.
DISCORD_GUILD_ID=replace-with-discord-server-id

# Discord member verification portal.
# Recommended: use a separate low-permission verification bot/app.
DISCORD_VERIFY_BOT_TOKEN=replace-with-verification-bot-token
DISCORD_VERIFY_GUILD_ID=replace-with-discord-server-id
DISCORD_VERIFY_CLIENT_ID=replace-with-verification-application-id
DISCORD_VERIFY_CLIENT_SECRET=replace-with-verification-client-secret
DISCORD_VERIFY_PUBLIC_BASE_URL=https://testrpc.qubitor.org
DISCORD_VERIFY_REDIRECT_URI=https://testrpc.qubitor.org/verify/callback
DISCORD_VERIFY_ROLE_NAME=Verified
DISCORD_SERVER_INVITE_URL=https://discord.gg/replace-with-invite

# Optional fallback if you intentionally use the setup bot for verification.
DISCORD_CLIENT_ID=replace-with-discord-application-id
DISCORD_CLIENT_SECRET=replace-with-discord-client-secret

# Optional: set to 1 to print planned writes without changing Discord.
DISCORD_DRY_RUN=0
