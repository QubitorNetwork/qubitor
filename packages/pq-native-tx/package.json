{
  "name": "@qubitor/pq-native-tx",
  "version": "0.1.1",
  "private": false,
  "description": "Qubitor PQ-native transaction helpers for ML-DSA key material, signing, encoding, and RPC submission.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/index.test.ts",
    "testnet:rotate-faucet": "tsx scripts/rotate-testnet-faucet.ts"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.1",
    "viem": "^2.38.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
