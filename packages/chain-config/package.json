{
  "name": "@qubitor/chain-config",
  "version": "0.1.1",
  "private": false,
  "description": "Shared Qubitor chain metadata, RPC defaults, currency metadata, and wallet network parameters.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/index.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
