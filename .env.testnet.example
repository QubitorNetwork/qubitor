# Qubitor public-testnet server login template.
# Copy to `.env.testnet` or `.env.testnet.local`, fill only server access
# details, and keep the local file private.
#
# Runtime node material is generated on the server by:
#   pnpm testnet:material:generate
#
# The generated material lives under:
#   artifacts/testnet/launch/<timestamp>/.env.testnet.local
#
# That generated file contains chain/runtime settings, node keys, bootnodes,
# PQ service vault material, Docker bind paths, and QUBITOR_EOA_TXS=0. Do not
# add those generated values to this login template.

# Primary dedicated Ubuntu server.
QUBITOR_TESTNET_SERVER_HOST=66.29.136.165
QUBITOR_TESTNET_SERVER_USER=replace-with-ubuntu-ssh-user
QUBITOR_TESTNET_SERVER_SSH_PORT=22
QUBITOR_TESTNET_SERVER_AUTH=password

# Password auth is interactive. Do not store a password in this file.
# If the server uses key auth instead, switch the auth mode and uncomment/fill:
# QUBITOR_TESTNET_SERVER_AUTH=key
QUBITOR_TESTNET_SERVER_SSH_KEY=~/.ssh/id_ed25519

# Optional second dedicated Ubuntu bootnode server.
QUBITOR_TESTNET_BOOTNODE_2_HOST=replace-with-second-bootnode-ip-or-dns
QUBITOR_TESTNET_BOOTNODE_2_USER=replace-with-second-bootnode-ssh-user
QUBITOR_TESTNET_BOOTNODE_2_AUTH=password

# Optional second-server key-auth form.
# QUBITOR_TESTNET_BOOTNODE_2_AUTH=key
# QUBITOR_TESTNET_BOOTNODE_2_SSH_KEY=~/.ssh/id_ed25519
